{
  "redirects": [
    { "source": "/app/docs", "destination": "/docs", "permanent": true },
    { "source": "/app/audit", "destination": "/audit", "permanent": true }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/app/diff", "destination": "/diff.html" },
    { "source": "/app", "destination": "/app.html" },
    { "source": "/diff", "destination": "/landing-diff.html" },
    { "source": "/docs", "destination": "/docs.html" },
    { "source": "/audit", "destination": "/audit.html" },
    { "source": "/privacy", "destination": "/privacy.html" },
    { "source": "/terms", "destination": "/terms.html" },
    { "source": "/", "destination": "/landing-convert.html" },
    { "source": "/(.*)", "destination": "/app.html" }
  ]
}
