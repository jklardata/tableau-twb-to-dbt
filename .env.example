# Copy to .env.local for local dev, set these in Vercel dashboard for production

# Anthropic (get from console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Stripe (get from dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_live_...
# or for testing:
# STRIPE_SECRET_KEY=sk_test_...

# Resend (get from resend.com/api-keys)
RESEND_API_KEY=re_...

# Resend audience ID (optional — for mailing list capture)
# Create an audience at resend.com/audiences
RESEND_AUDIENCE_ID=
